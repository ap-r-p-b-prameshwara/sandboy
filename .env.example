# PostgreSQL Configuration
POSTGRES_USER=sandbox_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PROD_DB=sandbox_prod
POSTGRES_SANDBOX_DB=sandbox_sandbox

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_minimum_256_bits
JWT_EXPIRATION=86400000

# Service Ports
GATEWAY_PROD_PORT=8080
GATEWAY_SANDBOX_PORT=8085
USER_SERVICE_PROD_PORT=8081
USER_SERVICE_SANDBOX_PORT=8082
AUTH_SERVICE_PROD_PORT=8083
AUTH_SERVICE_SANDBOX_PORT=8084
QRIS_SERVICE_PROD_PORT=8086
QRIS_SERVICE_SANDBOX_PORT=8087
CASHIN_SERVICE_PROD_PORT=8088
CASHIN_SERVICE_SANDBOX_PORT=8089

# Frontend Ports
MAIN_WEB_PORT=4200
QRIS_WEB_PORT=4201
CASHIN_WEB_PORT=4202
